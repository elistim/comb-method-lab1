{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "configure",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "default"],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure the project using CMake."
        },
        {
            "label": "build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "default"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build the C project using CMake."
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "build", "--target", "clean"],
            "group": "build",
            "problemMatcher": [],
            "detail": "Clean the build artifacts."
        },
        {
            "label": "run",
            "type": "shell",
            "command": "${workspaceFolder}\\build\\my_program.exe",
            "group": "test",
            "problemMatcher": [],
            "detail": "Run the compiled program.",
            "dependsOn": "build"
        },
        {
            "label": "debug-build",
            "type": "shell",
            "command": "cmake",
            "args": ["--build", "--preset", "debug"],
            "group": "build",
            "dependsOn": ["debug-configure"],
            "dependsOrder": "sequence",
            "problemMatcher": ["$gcc"],
            "detail": "Build Debug preset (build-debug/my_program.exe)"
        },
        {
            "label": "debug-configure",
            "type": "shell",
            "command": "cmake",
            "args": ["--preset", "debug"],
            "group": "build",
            "problemMatcher": [],
            "detail": "Configure Debug preset (build-debug)"
        }
    ]
}
